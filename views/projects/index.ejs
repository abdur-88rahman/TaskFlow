<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
  <div class="page-header">
    <div>
      <h1>My Projects</h1>
      <p>All projects you're a part of</p>
    </div>
    <a href="/projects/new" class="btn btn-primary" id="new-project-btn">+ New Project</a>
  </div>

  <% if (projects.length === 0) { %>
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
      </svg>
      <h3>No projects yet</h3>
      <p>Create your first project to start organizing your team's work</p>
      <a href="/projects/new" class="btn btn-primary">+ Create Project</a>
    </div>
  <% } else { %>
    <div class="card-grid">
      <% projects.forEach(project => { %>
        <a href="/projects/<%= project.id %>" class="card" style="text-decoration:none;color:inherit" id="project-<%= project.id %>">
          <div class="card-title"><%= project.name %></div>
          <% if (project.description) { %>
            <div class="card-desc"><%= project.description.substring(0, 120) %><%= project.description.length > 120 ? '...' : '' %></div>
          <% } %>
          <div class="card-meta">
            <span class="badge badge-<%= project.userRole === 'Admin' ? 'admin' : 'member' %>"><%= project.userRole %></span>
            <span>Created <%= new Date(project.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>

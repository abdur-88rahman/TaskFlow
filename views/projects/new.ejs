<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container">
  <div class="page-header">
    <div>
      <h1>Create New Project</h1>
      <p>Set up a new project for your team</p>
    </div>
    <a href="/projects" class="btn btn-secondary">← Back</a>
  </div>

  <div class="form-container">
    <div class="card" style="cursor:default">
      <% if (errors && errors.length > 0) { %>
        <% errors.forEach(err => { %>
          <div class="alert alert-error">✕ <%= err.msg %></div>
        <% }) %>
      <% } %>

      <form action="/projects" method="POST" id="create-project-form">
        <div class="form-group">
          <label for="name">Project Name</label>
          <input type="text" class="form-control" id="name" name="name" placeholder="e.g. Website Redesign" required>
        </div>

        <div class="form-group">
          <label for="description">Description (optional)</label>
          <textarea class="form-control" id="description" name="description" placeholder="What is this project about?" rows="4"></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-block" id="create-project-btn">Create Project</button>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
